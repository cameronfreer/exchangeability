import Exchangeability.Probability.CondIndep.Bounded.Approximation
import Exchangeability.Probability.CondIndep.Indicator

/-!
# Conditional Independence - Projection Theorems

This file proves that conditional independence allows projecting conditional
expectations from ŌÉ(Z,W) to ŌÉ(W).

## Main results

* `condExp_project_of_condIndep`: When Y ‚ä•‚ä•_W Z, conditioning on (Z,W) gives the
  same result as conditioning on W alone for indicator functions of Y.
* `condIndep_project`: Wrapper theorem using the projection property.

## Key insight

Conditional independence means that knowing Z provides no additional information
about Y beyond what W already provides. Therefore E[f(Y)|ŌÉ(Z,W)] = E[f(Y)|ŌÉ(W)].

## References

* Kallenberg (2005), *Probabilistic Symmetries and Invariance Principles*, Section 6.1
-/

open scoped Classical

noncomputable section
open scoped MeasureTheory ENNReal
open MeasureTheory ProbabilityTheory Set Exchangeability.Probability

variable {ő© őĪ ő≤ ő≥ : Type*}
variable [MeasurableSpace ő©] [MeasurableSpace őĪ] [MeasurableSpace ő≤] [MeasurableSpace ő≥]

set_option maxHeartbeats 500000 in
/-- **Conditional expectation projection from conditional independence (helper).**

When Y ‚ä•‚ä•_W Z, conditioning on (Z,W) gives the same result as conditioning on W alone
for indicator functions of Y.

This is a key technical lemma used to prove the main projection theorem.
-/
lemma condExp_project_of_condIndep (őľ : Measure ő©) [IsProbabilityMeasure őľ]
    (Y : ő© ‚Üí őĪ) (Z : ő© ‚Üí ő≤) (W : ő© ‚Üí ő≥)
    (hY : Measurable Y) (hZ : Measurable Z) (hW : Measurable W)
    (h_indep : CondIndep őľ Y Z W)
    {A : Set őĪ} (hA : MeasurableSet A) :
    őľ[ Set.indicator (Y ‚ĀĽ¬Ļ' A) (fun _ => (1 : ‚ĄĚ))
       | MeasurableSpace.comap (fun ŌČ => (Z ŌČ, W ŌČ)) (by infer_instance) ]
      =ŠĶź[őľ]
    őľ[ Set.indicator (Y ‚ĀĽ¬Ļ' A) (fun _ => (1 : ‚ĄĚ))
       | MeasurableSpace.comap W (by infer_instance) ] := by
  -- Strategy: Use uniqueness characterization of conditional expectation
  -- Show that both CEs have the same integrals on all ŌÉ(W)-measurable sets

  -- 0) Name the ambient instance (no abbrev in tactic mode - use let but pin explicitly everywhere)
  let m0 : MeasurableSpace ő© := ‚ÄĻMeasurableSpace ő©‚Äļ

  -- Sub-ŌÉ-algebras as plain values (never instances)
  let mW := MeasurableSpace.comap W (by infer_instance)
  let mZW := MeasurableSpace.comap (fun ŌČ => (Z ŌČ, W ŌČ)) (by infer_instance)
  let f := Set.indicator (Y ‚ĀĽ¬Ļ' A) (fun _ => (1 : ‚ĄĚ))

  -- ŌÉ-algebra ordering: ŌÉ(W) ‚äÜ ŌÉ(Z,W)
  have hle : mW ‚Č§ mZW := by
    intro s hs
    obtain ‚ü®T, hT_meas, rfl‚ü© := hs
    use Set.univ √óňĘ T
    constructor
    ¬∑ exact MeasurableSet.univ.prod hT_meas
    ¬∑ ext ŌČ; simp [Set.mem_preimage, Set.mem_prod]

  -- Integrability
  have hf_int : Integrable f őľ := by
    apply Integrable.indicator
    ¬∑ exact integrable_const (1 : ‚ĄĚ)
    ¬∑ exact hY hA

  -- Key insight: Use tower property and apply uniqueness on ŌÉ(Z,W)
  -- We show őľ[f|mW] has the same set integrals as f on all ŌÉ(Z,W)-sets

  -- ŌÉ-algebra orderings
  have hmZW_le : mZW ‚Č§ _ := (hZ.prodMk hW).comap_le  -- ŌÉ(Z,W) ‚Č§ ūĚďú(ő©)

  -- őľ[f|mW] is ŌÉ(W)-measurable, hence also ŌÉ(Z,W)-measurable (since mW ‚Č§ mZW)
  have hgm : AEStronglyMeasurable[mZW] (őľ[f | mW]) őľ :=
    stronglyMeasurable_condExp.aestronglyMeasurable.mono hle

  -- For any S ‚ąą ŌÉ(Z,W): ‚ąę_S őľ[f|mW] = ‚ąę_S f
  -- Use Dynkin ŌÄ-őĽ theorem: define C(s) := "integrals match on s"
  have hg_eq : ‚ąÄ s : Set ő©, MeasurableSet[mZW] s ‚Üí őľ s < ‚ąě ‚Üí
      ‚ąę x in s, (őľ[f | mW]) x ‚ąāőľ = ‚ąę x in s, f x ‚ąāőľ := by
    -- First show: ŌÉ(Z,W) is generated by rectangles Z‚ĀĽ¬Ļ(B) ‚ą© W‚ĀĽ¬Ļ(C)
    have mZW_gen : mZW = MeasurableSpace.generateFrom
        {s | ‚ąÉ (B : Set ő≤) (C : Set ő≥), MeasurableSet B ‚ąß MeasurableSet C ‚ąß
             s = Z ‚ĀĽ¬Ļ' B ‚ą© W ‚ĀĽ¬Ļ' C} := by
      -- ŌÉ(Z,W) = comap (Z,W) (ŌÉ(ő≤√óő≥))
      -- ŌÉ(ő≤√óő≥) = generateFrom {B √óňĘ C | ...} by generateFrom_prod
      -- comap commutes with generateFrom
      unfold mZW
      conv_lhs => arg 2; rw [‚Üź generateFrom_prod (őĪ := ő≤) (ő≤ := ő≥)]
      rw [MeasurableSpace.comap_generateFrom]
      congr 1
      ext s
      constructor
      ¬∑ intro ‚ü®t, ht_mem, ht_eq‚ü©
        -- t ‚ąą image2 (¬∑ √óňĘ ¬∑) ... means ‚ąÉ B C, t = B √óňĘ C
        -- ht_mem : t ‚ąą image2 (¬∑√óňĘ¬∑) {B | MeasurableSet B} {C | MeasurableSet C}
        simp only [Set.mem_image2, Set.mem_setOf_eq] at ht_mem
        obtain ‚ü®B, hB, C, hC, rfl‚ü© := ht_mem
        use B, C, hB, hC
        -- Need: (Z,W)‚ĀĽ¬Ļ(B √óňĘ C) = Z‚ĀĽ¬ĻB ‚ą© W‚ĀĽ¬ĻC
        rw [‚Üź ht_eq]
        ext ŌČ
        simp only [Set.mem_inter_iff, Set.mem_preimage, Set.mem_prod]
      ¬∑ intro ‚ü®B, C, hB, hC, hs_eq‚ü©
        -- s = Z‚ĀĽ¬ĻB ‚ą© W‚ĀĽ¬ĻC, need to show it's in the preimage image
        simp only [Set.mem_image, Set.mem_image2, Set.mem_setOf_eq]
        use B √óňĘ C
        refine ‚ü®‚ü®B, hB, C, hC, rfl‚ü©, ?_‚ü©
        rw [hs_eq]
        ext ŌČ
        simp only [Set.mem_inter_iff, Set.mem_preimage, Set.mem_prod]

    -- Rectangles form a ŌÄ-system
    have h_pi : IsPiSystem {s | ‚ąÉ (B : Set ő≤) (C : Set ő≥), MeasurableSet B ‚ąß MeasurableSet C ‚ąß
                                   s = Z ‚ĀĽ¬Ļ' B ‚ą© W ‚ĀĽ¬Ļ' C} := by
      -- Need to show: intersection of two rectangles is a rectangle
      intro s‚āĀ hs‚āĀ s‚āā hs‚āā _
      obtain ‚ü®B‚āĀ, C‚āĀ, hB‚āĀ, hC‚āĀ, rfl‚ü© := hs‚āĀ
      obtain ‚ü®B‚āā, C‚āā, hB‚āā, hC‚āā, rfl‚ü© := hs‚āā
      -- (Z‚ĀĽ¬ĻB‚āĀ ‚ą© W‚ĀĽ¬ĻC‚āĀ) ‚ą© (Z‚ĀĽ¬ĻB‚āā ‚ą© W‚ĀĽ¬ĻC‚āā) = Z‚ĀĽ¬Ļ(B‚āĀ ‚ą© B‚āā) ‚ą© W‚ĀĽ¬Ļ(C‚āĀ ‚ą© C‚āā)
      use B‚āĀ ‚ą© B‚āā, C‚āĀ ‚ą© C‚āā
      refine ‚ü®hB‚āĀ.inter hB‚āā, hC‚āĀ.inter hC‚āā, ?_‚ü©
      ext ŌČ
      simp only [Set.mem_inter_iff, Set.mem_preimage]
      tauto

    -- Apply ŌÄ-őĽ induction
    intro s hs hőľs
    apply MeasurableSpace.induction_on_inter (C := fun s _ => ‚ąę x in s, (őľ[f | mW]) x ‚ąāőľ = ‚ąę x in s, f x ‚ąāőľ)
      mZW_gen h_pi

    ¬∑ -- Empty set
      simp

    ¬∑ -- Basic case: rectangles Z‚ĀĽ¬Ļ(B) ‚ą© W‚ĀĽ¬Ļ(C)
      intro t ht
      obtain ‚ü®B, C, hB, hC, rfl‚ü© := ht
      -- Strategy: Use that Z‚ĀĽ¬ĻB ‚ą© W‚ĀĽ¬ĻC is in mZW, so by tower property and setIntegral_condExp
      -- Key: Z‚ĀĽ¬ĻB ‚ą© W‚ĀĽ¬ĻC ‚ąą ŌÉ(Z,W), so ‚ąę_{Z‚ĀĽ¬ĻB ‚ą© W‚ĀĽ¬ĻC} őľ[f|mZW] = ‚ąę_{Z‚ĀĽ¬ĻB ‚ą© W‚ĀĽ¬ĻC} f
      -- And we'll show ‚ąę_{Z‚ĀĽ¬ĻB ‚ą© W‚ĀĽ¬ĻC} őľ[f|mW] = ‚ąę_{Z‚ĀĽ¬ĻB ‚ą© W‚ĀĽ¬ĻC} őľ[f|mZW]

      classical

      -- 1) Ambient measurability, explicitly pinned to m0
      have hZ_m0 : @Measurable ő© ő≤ m0 _ Z := by simpa [m0] using hZ
      have hW_m0 : @Measurable ő© ő≥ m0 _ W := by simpa [m0] using hW

      have hBpre_m0 : @MeasurableSet ő© m0 (Z ‚ĀĽ¬Ļ' B) := hB.preimage hZ_m0
      have hCpre_m0 : @MeasurableSet ő© m0 (W ‚ĀĽ¬Ļ' C) := hC.preimage hW_m0

      -- Sub-ŌÉ-algebra ordering
      have hmW_le : mW ‚Č§ m0 := hW_m0.comap_le

      -- mZW-measurable versions of Z and W (by construction of comap)
      have hZ_mZW : @Measurable ő© ő≤ mZW _ Z := measurable_fst.comp (Measurable.of_comap_le le_rfl)
      have hW_mZW : @Measurable ő© ő≥ mZW _ W := measurable_snd.comp (Measurable.of_comap_le le_rfl)

      -- mW-measurable version of W (by construction of mW := comap W)
      have hW_mW : @Measurable ő© ő≥ mW _ W := Measurable.of_comap_le le_rfl

      have hBpre : @MeasurableSet ő© mZW (Z ‚ĀĽ¬Ļ' B) := hB.preimage hZ_mZW
      have hCpre_mZW : @MeasurableSet ő© mZW (W ‚ĀĽ¬Ļ' C) := hC.preimage hW_mZW
      have hCpre : @MeasurableSet ő© mW (W ‚ĀĽ¬Ļ' C) := hC.preimage hW_mW

      -- Convenience name for indicator on Z‚ĀĽ¬ĻB (f is already defined in outer scope)
      set gB : ő© ‚Üí ‚ĄĚ := (Z ‚ĀĽ¬Ļ' B).indicator (fun _ => (1 : ‚ĄĚ)) with hgB_def

      -- gB measurability
      have hsm_gB : @StronglyMeasurable ő© ‚ĄĚ _ m0 gB :=
        stronglyMeasurable_const.indicator hBpre_m0

      -- CE basic facts
      have hsm_ce_mW : @StronglyMeasurable ő© ‚ĄĚ _ mW (őľ[f | mW]) :=
        stronglyMeasurable_condExp
      have hInt_ce : Integrable (őľ[f | mW]) őľ :=
        integrable_condExp

      -- AE version (for use later, keep mW-measurable)
      have haesm_ce : @AEStronglyMeasurable ő© ‚ĄĚ _ mW _ (őľ[f | mW]) őľ :=
        hsm_ce_mW.aestronglyMeasurable

      -- Canonical product ‚ÜĒ indicator identity (use often)
      have h_mul_eq_indicator :
          (fun ŌČ => őľ[f|mW] ŌČ * gB ŌČ) = (Z ‚ĀĽ¬Ļ' B).indicator (őľ[f|mW]) := by
        funext ŌČ; by_cases hŌČ : ŌČ ‚ąą Z ‚ĀĽ¬Ļ' B
        ¬∑ simp only [hgB_def, Set.indicator_of_mem hŌČ, mul_one]
        ¬∑ simp only [hgB_def, Set.indicator_of_notMem hŌČ, mul_zero]

      -- Product integrability: rewrite to indicator, then use Integrable.indicator
      have hint_prod : Integrable (fun ŌČ => őľ[f | mW] ŌČ * gB ŌČ) őľ := by
        simpa [h_mul_eq_indicator] using hInt_ce.indicator hBpre_m0

      -- Rectangle is in mZW
      have hrect : MeasurableSet[mZW] (Z ‚ĀĽ¬Ļ' B ‚ą© W ‚ĀĽ¬Ļ' C) := by
        -- Z‚ĀĽ¬ĻB ‚ą© W‚ĀĽ¬ĻC = (Z,W)‚ĀĽ¬Ļ(B √óňĘ C)
        have : Z ‚ĀĽ¬Ļ' B ‚ą© W ‚ĀĽ¬Ļ' C = (fun ŌČ => (Z ŌČ, W ŌČ)) ‚ĀĽ¬Ļ' (B √óňĘ C) := by
          ext ŌČ
          simp only [Set.mem_inter_iff, Set.mem_preimage, Set.mem_prod]
        rw [this]
        exact measurableSet_preimage (Measurable.of_comap_le le_rfl) (hB.prod hC)

      -- By setIntegral_condExp on mZW
      have h1 : ‚ąę x in Z ‚ĀĽ¬Ļ' B ‚ą© W ‚ĀĽ¬Ļ' C, (őľ[f | mZW]) x ‚ąāőľ = ‚ąę x in Z ‚ĀĽ¬Ļ' B ‚ą© W ‚ĀĽ¬Ļ' C, f x ‚ąāőľ := by
        exact setIntegral_condExp hmZW_le hf_int hrect

      -- By tower property: E[E[f|mZW]|mW] = E[f|mW] (since mW ‚Č§ mZW)
      have h2 : őľ[őľ[f | mZW] | mW] =ŠĶź[őľ] őľ[f | mW] := by
        exact condExp_condExp_of_le hle hmZW_le

      -- So ‚ąę_{rectangle} E[f|mW] = ‚ąę_{rectangle} E[E[f|mZW]|mW]
      have h3 : ‚ąę x in Z ‚ĀĽ¬Ļ' B ‚ą© W ‚ĀĽ¬Ļ' C, (őľ[f | mW]) x ‚ąāőľ =
                ‚ąę x in Z ‚ĀĽ¬Ļ' B ‚ą© W ‚ĀĽ¬Ļ' C, (őľ[őľ[f | mZW] | mW]) x ‚ąāőľ := by
        apply setIntegral_congr_ae (hmZW_le _ hrect)
        filter_upwards [h2] with x hx _
        exact hx.symm

      -- Now combine: ‚ąę őľ[f|mW] = ‚ąę őľ[őľ[f|mZW]|mW] (by h3), and we want ‚ąę őľ[f|mW] = ‚ąę f
      calc ‚ąę x in Z ‚ĀĽ¬Ļ' B ‚ą© W ‚ĀĽ¬Ļ' C, (őľ[f | mW]) x ‚ąāőľ
          = ‚ąę x in Z ‚ĀĽ¬Ļ' B ‚ą© W ‚ĀĽ¬Ļ' C, (őľ[őľ[f | mZW] | mW]) x ‚ąāőľ := h3
        _ = ‚ąę x in Z ‚ĀĽ¬Ļ' B ‚ą© W ‚ĀĽ¬Ļ' C, f x ‚ąāőľ := by
          -- Key: Use CondIndep to show ‚ąę_{Z‚ĀĽ¬ĻB ‚ą© W‚ĀĽ¬ĻC} őľ[őľ[f|mZW]|mW] = ‚ąę_{Z‚ĀĽ¬ĻB ‚ą© W‚ĀĽ¬ĻC} f
          -- By tower property h2, őľ[őľ[f|mZW]|mW] =ŠĶź őľ[f|mW], so enough to show ‚ąę_{rect} őľ[f|mW] = ‚ąę_{rect} f

          -- Rewrite LHS using h2
          have : ‚ąę x in Z ‚ĀĽ¬Ļ' B ‚ą© W ‚ĀĽ¬Ļ' C, (őľ[őľ[f | mZW] | mW]) x ‚ąāőľ =
                 ‚ąę x in Z ‚ĀĽ¬Ļ' B ‚ą© W ‚ĀĽ¬Ļ' C, (őľ[f | mW]) x ‚ąāőľ := by
            apply setIntegral_congr_ae (hmZW_le _ hrect)
            filter_upwards [h2] with x hx _
            exact hx
          rw [this]

          -- Now show: ‚ąę_{Z‚ĀĽ¬ĻB ‚ą© W‚ĀĽ¬ĻC} őľ[f|mW] = ‚ąę_{Z‚ĀĽ¬ĻB ‚ą© W‚ĀĽ¬ĻC} f
          -- Strategy: Use CondIndep to factor through W‚ĀĽ¬ĻC

          -- Apply CondIndep to sets A and B
          have hCI := h_indep A B hA hB
          -- Gives: E[1_A(Y) ¬∑ 1_B(Z) | ŌÉ(W)] =ŠĶź E[1_A(Y) | ŌÉ(W)] ¬∑ E[1_B(Z) | ŌÉ(W)]

          -- W‚ĀĽ¬ĻC is ŌÉ(W)-measurable
          have hC_meas : MeasurableSet[mW] (W ‚ĀĽ¬Ļ' C) := by
            exact measurableSet_preimage (Measurable.of_comap_le le_rfl) hC

          -- Integrability of gB (already defined at top of rectangle case)
          have hint_B : Integrable gB őľ := by
            apply Integrable.indicator
            ¬∑ exact integrable_const 1
            ¬∑ exact hBpre_m0

          -- Integrability of f * gB: f ¬∑ gB = f ¬∑ 1_{Z‚ĀĽ¬ĻB} = f restricted to Z‚ĀĽ¬ĻB
          have hprod_int : Integrable (f * gB) őľ := by
            -- f * gB = (Y‚ĀĽ¬ĻA).indicator(1) * (Z‚ĀĽ¬ĻB).indicator(1)
            -- This is bounded by 1, so integrable
            have : (f * gB) = (Y ‚ĀĽ¬Ļ' A ‚ą© Z ‚ĀĽ¬Ļ' B).indicator (fun _ => (1 : ‚ĄĚ)) := by
              funext ŌČ
              simp only [Pi.mul_apply, f, gB, Set.indicator_apply]
              by_cases hY : ŌČ ‚ąą Y ‚ĀĽ¬Ļ' A <;> by_cases hZ : ŌČ ‚ąą Z ‚ĀĽ¬Ļ' B
              ¬∑ simp [hY, hZ, Set.mem_inter_iff]
              ¬∑ simp [hY, hZ, Set.mem_inter_iff]
              ¬∑ simp [hY, hZ, Set.mem_inter_iff]
              ¬∑ simp [hY, hZ, Set.mem_inter_iff]
            rw [this]
            apply Integrable.indicator
            ¬∑ exact integrable_const 1
            ¬∑ exact (hY hA).inter (hZ hB)

          -- Chain of equalities: ‚ąę_{Z‚ĀĽ¬ĻB ‚ą© W‚ĀĽ¬ĻC} őľ[f|mW] = ‚ąę_{Z‚ĀĽ¬ĻB ‚ą© W‚ĀĽ¬ĻC} f

          -- Helper: W‚ĀĽ¬ĻC is measurable in m0 (already defined above, but re-proving for clarity)
          -- (Actually, use the one from the prelude - this line is redundant)

          calc ‚ąę x in Z ‚ĀĽ¬Ļ' B ‚ą© W ‚ĀĽ¬Ļ' C, (őľ[f | mW]) x ‚ąāőľ
              = ‚ąę x in W ‚ĀĽ¬Ļ' C, (őľ[f | mW] * gB) x ‚ąāőľ := by
                -- Rewrite using indicator: ‚ąę_{W‚ĀĽ¬ĻC ‚ą© Z‚ĀĽ¬ĻB} őľ[f|mW] = ‚ąę_{W‚ĀĽ¬ĻC} (őľ[f|mW] * gB)
                -- First: LHS = ‚ąę_{W‚ĀĽ¬ĻC} (Z‚ĀĽ¬ĻB).indicator(őľ[f|mW])
                have h1 : ‚ąę ŌČ in W ‚ĀĽ¬Ļ' C ‚ą© Z ‚ĀĽ¬Ļ' B, őľ[f|mW] ŌČ ‚ąāőľ
                        = ‚ąę ŌČ in W ‚ĀĽ¬Ļ' C, (Z ‚ĀĽ¬Ļ' B).indicator (őľ[f|mW]) ŌČ ‚ąāőľ := by
                  rw [setIntegral_indicator hBpre_m0]
                -- Second: RHS uses h_mul_eq_indicator
                have h2 : ‚ąę ŌČ in W ‚ĀĽ¬Ļ' C, (Z ‚ĀĽ¬Ļ' B).indicator (őľ[f|mW]) ŌČ ‚ąāőľ
                        = ‚ąę ŌČ in W ‚ĀĽ¬Ļ' C, (őľ[f|mW] ŌČ * gB ŌČ) ‚ąāőľ := by
                  congr 1
                  exact h_mul_eq_indicator.symm
                -- Combine
                rw [Set.inter_comm]
                exact h1.trans h2
            _ = ‚ąę x in W ‚ĀĽ¬Ļ' C, (őľ[f | mW] * őľ[gB | mW]) x ‚ąāőľ := by
                -- Key: For ŌÉ(W)-measurable h: őľ[h ¬∑ g|ŌÉ(W)] =ŠĶź h ¬∑ őľ[g|ŌÉ(W)]
                -- Since őľ[f|mW] is mW-measurable, integrating over W‚ĀĽ¬ĻC ‚ąą mW gives equality
                have h_pull : őľ[(őľ[f | mW]) * gB | mW] =ŠĶź[őľ] (őľ[f | mW]) * őľ[gB | mW] := by
                  refine condExp_mul_of_aestronglyMeasurable_left ?_ ?_ hint_B
                  ¬∑ exact haesm_ce
                  ¬∑ -- Product: bounded measurable * integrable = integrable
                    -- Use hint_prod from prelude
                    exact hint_prod
                -- Apply setIntegral_condExp and the pull-out property
                calc ‚ąę x in W ‚ĀĽ¬Ļ' C, (őľ[f | mW] * gB) x ‚ąāőľ
                    = ‚ąę x in W ‚ĀĽ¬Ļ' C, (őľ[(őľ[f | mW]) * gB | mW]) x ‚ąāőľ := by
                      -- Use setIntegral_condExp: ‚ąę_{W‚ĀĽ¬ĻC} őľ[h|mW] = ‚ąę_{W‚ĀĽ¬ĻC} h for W‚ĀĽ¬ĻC ‚ąą mW
                      -- Avoids needing to prove (őľ[f|mW]) * gB is mW-measurable
                      have h_set_eq :
                          ‚ąę x in W ‚ĀĽ¬Ļ' C, őľ[(őľ[f | mW]) * gB | mW] x ‚ąāőľ
                        = ‚ąę x in W ‚ĀĽ¬Ļ' C, ((őľ[f | mW]) * gB) x ‚ąāőľ := by
                        simpa using
                          (setIntegral_condExp (őľ := őľ) (m := mW)
                            (hm := hmW_le) (hs := hCpre) (hf := hint_prod))
                      exact h_set_eq.symm
                  _ = ‚ąę x in W ‚ĀĽ¬Ļ' C, ((őľ[f | mW]) * őľ[gB | mW]) x ‚ąāőľ := by
                      exact setIntegral_congr_ae (hmW_le _ hC_meas) (by filter_upwards [h_pull] with x hx _; exact hx)
            _ = ‚ąę x in W ‚ĀĽ¬Ļ' C, (őľ[f * gB | mW]) x ‚ąāőľ := by
                -- Reverse CondIndep factorization: E[f|mW] ¬∑ E[gB|mW] =ŠĶź E[f ¬∑ gB|mW]
                -- Use hCI which states: őľ[f ¬∑ gB | mW] =ŠĶź őľ[f | mW] ¬∑ őľ[gB | mW]
                exact setIntegral_congr_ae (hmW_le _ hC_meas) (by filter_upwards [hCI] with x hx _; exact hx.symm)
            _ = ‚ąę x in W ‚ĀĽ¬Ļ' C, (f * gB) x ‚ąāőľ := by
                -- Apply setIntegral_condExp
                exact setIntegral_condExp hmW_le hprod_int hC_meas
            _ = ‚ąę x in Z ‚ĀĽ¬Ļ' B ‚ą© W ‚ĀĽ¬Ļ' C, f x ‚ąāőľ := by
                -- Reverse the indicator rewrite: ‚ąę_{W‚ĀĽ¬ĻC} f¬∑gB = ‚ąę_{W‚ĀĽ¬ĻC ‚ą© Z‚ĀĽ¬ĻB} f
                -- First: prove pointwise equality f * gB = (Z‚ĀĽ¬ĻB).indicator f
                have h_fg_indicator : (fun ŌČ => f ŌČ * gB ŌČ) = (Z ‚ĀĽ¬Ļ' B).indicator f := by
                  funext ŌČ; by_cases hŌČ : ŌČ ‚ąą Z ‚ĀĽ¬Ļ' B
                  ¬∑ simp only [hgB_def, Set.indicator_of_mem hŌČ, mul_one]
                  ¬∑ simp only [hgB_def, Set.indicator_of_notMem hŌČ, mul_zero]
                -- Second: rewrite integral
                calc ‚ąę ŌČ in W ‚ĀĽ¬Ļ' C, (f ŌČ * gB ŌČ) ‚ąāőľ
                    = ‚ąę ŌČ in W ‚ĀĽ¬Ļ' C, (Z ‚ĀĽ¬Ļ' B).indicator f ŌČ ‚ąāőľ := by
                      congr 1
                  _ = ‚ąę ŌČ in W ‚ĀĽ¬Ļ' C ‚ą© Z ‚ĀĽ¬Ļ' B, f ŌČ ‚ąāőľ := by
                      rw [setIntegral_indicator hBpre_m0]
                  _ = ‚ąę ŌČ in Z ‚ĀĽ¬Ļ' B ‚ą© W ‚ĀĽ¬Ļ' C, f ŌČ ‚ąāőľ := by
                      rw [Set.inter_comm]

    ¬∑ -- Complement
      intro t htm ht_ind
      -- For complement: ‚ąę_{t} g + ‚ąę_{tŠ∂ú} g = ‚ąę_ő© g, so ‚ąę_{tŠ∂ú} g = ‚ąę_ő© g - ‚ąę_t g
      have h_add : ‚ąę x in t, (őľ[f | mW]) x ‚ąāőľ + ‚ąę x in tŠ∂ú, (őľ[f | mW]) x ‚ąāőľ = ‚ąę x, (őľ[f | mW]) x ‚ąāőľ := by
        exact integral_add_compl‚āÄ (hmZW_le _ htm).nullMeasurableSet integrable_condExp
      have h_add' : ‚ąę x in t, f x ‚ąāőľ + ‚ąę x in tŠ∂ú, f x ‚ąāőľ = ‚ąę x, f x ‚ąāőľ := by
        exact integral_add_compl‚āÄ (hmZW_le _ htm).nullMeasurableSet hf_int
      -- ht_ind is the equality for t, use it to substitute in h_add
      rw [ht_ind] at h_add
      -- Now we have: ‚ąę_t f + ‚ąę_{tŠ∂ú} E[f|mW] = ‚ąę E[f|mW]
      -- And we know: ‚ąę_t f + ‚ąę_{tŠ∂ú} f = ‚ąę f
      -- Also: ‚ąę E[f|mW] = ‚ąę f (by conditional expectation property)
      have h_total : ‚ąę x, (őľ[f | mW]) x ‚ąāőľ = ‚ąę x, f x ‚ąāőľ := by
        -- Use integral_condExp: ‚ąę őľ[f|m] = ‚ąę f
        -- Requires SigmaFinite (őľ.trim hle_amb), which follows from IsProbabilityMeasure
        -- Chain: IsProbabilityMeasure ‚Üí IsFiniteMeasure ‚Üí IsFiniteMeasure.trim ‚Üí SigmaFinite.trim
        have hle_amb : mW ‚Č§ _ := le_trans hle hmZW_le
        exact integral_condExp hle_amb
      linarith

    ¬∑ -- Countable disjoint union
      intro t_seq hdisjoint htm_seq ht_ind_seq
      -- For disjoint union: ‚ąę_{‚čÉŠĶĘ tŠĶĘ} g = ő£ŠĶĘ ‚ąę_{tŠĶĘ} g
      -- Use HasSum for both sides and show they're equal term by term
      -- Convert Disjoint to proper form for hasSum_integral_iUnion
      have hd : Pairwise (Function.onFun Disjoint t_seq) := hdisjoint
      -- Each t_seq i is measurable in ambient space since mZW ‚Č§ ambient
      have h1 := hasSum_integral_iUnion (fun i => hmZW_le _ (htm_seq i)) hd
        (integrable_condExp : Integrable (őľ[f | mW]) őľ).integrableOn
      have h2 := hasSum_integral_iUnion (fun i => hmZW_le _ (htm_seq i)) hd hf_int.integrableOn
      -- Show the terms are equal using ht_ind_seq, so the sums are equal by uniqueness
      have h_eq : (fun i => ‚ąę x in t_seq i, (őľ[f | mW]) x ‚ąāőľ) = (fun i => ‚ąę x in t_seq i, f x ‚ąāőľ) :=
        funext ht_ind_seq
      exact h1.unique (h_eq ‚Ėł h2)

    ¬∑ exact hs

  -- Apply uniqueness: őľ[f|mW] =ŠĶź őľ[f|mZW]
  exact (ae_eq_condExp_of_forall_setIntegral_eq hmZW_le hf_int
    (fun _ _ _ => integrable_condExp.integrableOn) hg_eq hgm).symm

